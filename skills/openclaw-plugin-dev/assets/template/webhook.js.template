// Webhook targets registry (for multi-account support)
const webhookTargets = new Map();

/**
 * Normalize webhook path
 */
function normalizeWebhookPath(raw) {
  const trimmed = (raw || "").trim();
  if (!trimmed) return "/";
  const withSlash = trimmed.startsWith("/") ? trimmed : `/${trimmed}`;
  if (withSlash.length > 1 && withSlash.endsWith("/")) {
    return withSlash.slice(0, -1);
  }
  return withSlash;
}

/**
 * Register a webhook target
 */
export function registerWebhookTarget(target) {
  const key = normalizeWebhookPath(target.path);
  const entry = { ...target, path: key };
  webhookTargets.set(key, entry);
  return () => {
    webhookTargets.delete(key);
  };
}

