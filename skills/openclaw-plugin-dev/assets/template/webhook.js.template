/**
 * Process inbound message through OpenClaw
 * TODO: Customize for channel-specific needs
 *
 * @param {Object} params - Process parameters
 * @param {Object} params.message - Parsed message
 * @param {Object} params.account - Resolved account
 * @param {Object} params.config - OpenClaw config
 */
async function processInboundMessage({ message, account, config }) {
  const runtime = getRuntime();
  const core = runtime.channel;

  const senderId = message.fromUser;
  const msgType = message.msgType || "text";
  const rawContent = message.content || "";
  const chatType = message.chatType || "single";
  const chatId = message.chatId || "";
  const isGroupChat = chatType === "group" && chatId;

  // Use chat ID for group sessions, sender ID for direct messages
  const peerId = isGroupChat ? chatId : senderId;
  const peerKind = isGroupChat ? "group" : "dm";
  const conversationId = isGroupChat
    ? `{{CHANNEL_ID}}:group:${chatId}`
    : `{{CHANNEL_ID}}:${senderId}`;

  logger.info("Processing inbound message", {
    from: senderId,
    chatType: peerKind,
    content: rawContent.substring(0, 50),
  });

  // ==========================================================================
  // TODO: Add channel-specific preprocessing
  // ==========================================================================
  // Examples:
  // - Group mention gating (only respond when @mentioned)
  // - Message filtering
  // - Admin user detection
  // - Command allowlist checking

  // ==========================================================================
  // Resolve route
  // ==========================================================================
  const route = core.routing.resolveAgentRoute({
    cfg: config,
    channel: "{{CHANNEL_ID}}",
    accountId: account.accountId,
    peer: {
      kind: peerKind,
      id: peerId,
    },
  });

  // ==========================================================================
  // Build inbound context
  // ==========================================================================
  const storePath = core.session.resolveStorePath(config.session?.store, {
    agentId: route.agentId,
  });
  const envelopeOptions = core.reply.resolveEnvelopeFormatOptions(config);
  const previousTimestamp = core.session.readSessionUpdatedAt({
    storePath,
    sessionKey: route.sessionKey,
  });

  // Prefix sender ID in group contexts
  const senderLabel = isGroupChat ? `[${senderId}]` : senderId;
  const body = core.reply.formatAgentEnvelope({
    channel: isGroupChat ? "{{CHANNEL_LABEL}} Group" : "{{CHANNEL_LABEL}}",
    from: senderLabel,
    timestamp: Date.now(),
    previousTimestamp,
    envelope: envelopeOptions,
    body: rawContent,
  });

  // ==========================================================================
  // TODO: Handle media attachments
  // ==========================================================================
  // If message contains images or files, download and attach them
  // Example:
  // const mediaPaths = [];
  // const mediaTypes = [];
  // if (message.imageUrl) {
  //   const localPath = await downloadMedia(message.imageUrl, account);
  //   mediaPaths.push(localPath);
  //   mediaTypes.push("image/jpeg");
  // }

  // ==========================================================================
  // Build context payload
  // ==========================================================================
  const ctxPayload = core.reply.finalizeInboundContext({
    Body: body,
    RawBody: rawContent,
    CommandBody: rawContent,
    From: `{{CHANNEL_ID}}:${senderId}`,
    To: conversationId,
    SessionKey: route.sessionKey,
    AccountId: route.accountId,
    ChatType: isGroupChat ? "group" : "direct",
    ConversationLabel: isGroupChat ? `Group ${chatId}` : senderId,
    SenderName: senderId,
    SenderId: senderId,
    GroupId: isGroupChat ? chatId : undefined,
    Provider: "{{CHANNEL_ID}}",
    Surface: "{{CHANNEL_ID}}",
    OriginatingChannel: "{{CHANNEL_ID}}",
    OriginatingTo: conversationId,
    CommandAuthorized: true,
    // TODO: Add media if present
    // MediaPaths: mediaPaths,
    // MediaTypes: mediaTypes,
  });

  // ==========================================================================
  // Record session metadata
  // ==========================================================================
  void core.session
    .recordSessionMetaFromInbound({
      storePath,
      sessionKey: ctxPayload.SessionKey ?? route.sessionKey,
      ctx: ctxPayload,
    })
    .catch((err) => {
      logger.error("Failed to update session meta", { error: err.message });
    });

  // ==========================================================================
  // Dispatch reply through OpenClaw
  // ==========================================================================
  await core.reply.dispatchReplyWithBufferedBlockDispatcher({
    ctx: ctxPayload,
    cfg: config,
    dispatcherOptions: {
      deliver: async (payload, info) => {
        logger.info("Delivering reply", {
          kind: info.kind,
          textPreview: (payload.text || "").substring(0, 50),
        });

        // ==========================================================================
        // TODO: Deliver reply to channel
        // ==========================================================================
        // Use outbound adapter or direct API call to send the reply
        // Example:
        // const channelPlugin = create{{CHANNEL_CLASS}}ChannelPlugin({ defaultAccountId: "default" });
        // await channelPlugin.outbound.sendText({
        //   cfg: config,
        //   to: isGroupChat ? chatId : senderId,
        //   text: payload.text,
        //   accountId: account.accountId,
        // });
      },
      onError: async (err, info) => {
        logger.error("Reply failed", { error: err.message, kind: info.kind });
        // TODO: Handle error (send error message to user, log, etc.)
      },
    },
  });
}
